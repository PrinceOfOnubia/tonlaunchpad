# =============================================================================
# TonPad — environment
# Copy to `.env.local` (which is gitignored) and fill in real values.
# =============================================================================

# Backend HTTP API root.
NEXT_PUBLIC_API_URL=

# Public URL where the dApp is served.
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_APP_URL=https://tonpad.org

NEXT_PUBLIC_FACTORY_ADDRESS=
NEXT_PUBLIC_TON_NETWORK=
NEXT_PUBLIC_TONCENTER_ENDPOINT=
NEXT_PUBLIC_TONCONNECT_MANIFEST_URL=https://tonpad.org/tonconnect-manifest.json

# Backend / indexer
DATABASE_URL=
TONCENTER_ENDPOINT=
TONCENTER_API_KEY=
FACTORY_ADDRESS=
PLATFORM_TON_TREASURY=
PLATFORM_TOKEN_TREASURY=
LIQUIDITY_TREASURY=
NETWORK=
PORT=4000
FRONTEND_ORIGIN=https://tonpad.org
BACKEND_PUBLIC_URL=
PUBLIC_UPLOAD_BASE_URL=
UPLOAD_DIR=backend/uploads
