# =============================================================================
# TonPad — environment
# Copy to `.env.local` (which is gitignored) and fill in real values.
# =============================================================================

# Backend HTTP API root. REQUIRED — without it the UI shows empty placeholders
# (em-dashes, "no tokens yet", etc.) instead of fake data.
#   Local dev:   http://localhost:8080/api
#   Production:  https://api.tonpad.app
NEXT_PUBLIC_API_URL=

# Public URL where the dApp is served. Used to build the TonConnect manifest URL
# (`<NEXT_PUBLIC_SITE_URL>/tonconnect-manifest.json`).
# Leave empty in dev — the provider falls back to window.location.origin.
# In production set it to your deployed domain (no trailing slash).
NEXT_PUBLIC_SITE_URL=
