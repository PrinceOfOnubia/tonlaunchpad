# =============================================================================
# TonPad — environment
# Copy to `.env.local` (which is gitignored) and fill in real values.
# =============================================================================

# Backend HTTP API root. REQUIRED — without it the UI shows empty placeholders
# (em-dashes, "no tokens yet", etc.) instead of fake data.
#   Local dev:   http://localhost:4000/api
#   Production:  https://your-railway-or-render-domain/api
NEXT_PUBLIC_API_URL=

# Public URL where the dApp is served. Used to build the TonConnect manifest URL
# (`<NEXT_PUBLIC_SITE_URL>/tonconnect-manifest.json`).
# Leave empty in dev — the provider falls back to window.location.origin.
# In production set it to your deployed domain (no trailing slash).
NEXT_PUBLIC_SITE_URL=

NEXT_PUBLIC_FACTORY_ADDRESS=EQCadGgX-fT-oYaR5iyrCPHYTrXWjx1Pmcxj9_E83qoHuwoR
NEXT_PUBLIC_DEX_ADAPTER_ADDRESS=EQAxVYGGW85GzumFpfoXPm6SJmSlxB-n7eNEZDYq4YH5sUcp
NEXT_PUBLIC_TON_NETWORK=testnet
NEXT_PUBLIC_TONCENTER_ENDPOINT=https://testnet.toncenter.com/api/v2/jsonRPC

# Backend / indexer
DATABASE_URL=
TONCENTER_ENDPOINT=https://testnet.toncenter.com/api/v2/jsonRPC
TONCENTER_API_KEY=
FACTORY_ADDRESS=EQCadGgX-fT-oYaR5iyrCPHYTrXWjx1Pmcxj9_E83qoHuwoR
DEX_ADAPTER_ADDRESS=EQAxVYGGW85GzumFpfoXPm6SJmSlxB-n7eNEZDYq4YH5sUcp
NETWORK=testnet
PORT=4000
FRONTEND_ORIGIN=https://tonlaunchpad.vercel.app
