# =============================================================================
# TonPad — Environment Variables
# Copy to `.env.local` and fill in real values.
# =============================================================================

# Backend HTTP API root. Required.
# Example for local dev:   http://localhost:8080/api
# Example for production:  https://api.tonpad.fun
NEXT_PUBLIC_API_URL=

# Public URL where /tonconnect-manifest.json will be served (production).
# In dev TonConnectProvider will fall back to window.location.origin.
NEXT_PUBLIC_SITE_URL=
