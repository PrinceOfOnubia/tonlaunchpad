generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LaunchStatus {
  upcoming
  live
  succeeded
  failed
}

enum TransactionType {
  launch
  contribute
  claim
  refund
  treasury
}

model Launch {
  id                      String        @id @default(cuid())
  tokenName               String
  symbol                  String
  description             String        @default("")
  logoUrl                 String?
  metadataUrl             String?
  creatorWallet           String
  factoryAddress          String
  tokenMasterAddress      String?       @unique
  presalePoolAddress      String?       @unique
  txHash                  String?       @unique
  softCap                 Float
  hardCap                 Float
  raisedTon               Float         @default(0)
  liquidityPercent        Float
  status                  LaunchStatus  @default(upcoming)
  startTime               DateTime
  endTime                 DateTime
  totalSupply             Float         @default(0)
  decimals                Int           @default(9)
  presaleRate             Float         @default(0)
  minContribution         Float?
  maxContribution         Float?
  presaleAllocation       Float         @default(0)
  liquidityAllocation     Float         @default(0)
  creatorAllocation       Float         @default(0)
  platformTonTreasury     String?
  platformTokenTreasury   String?
  liquidityTreasury       String?
  platformTonFeeBps       Int           @default(500)
  platformTokenFeeBps     Int           @default(100)
  platformTokenFeeAmount  Float         @default(0)
  platformTokenFeeTonTreasuryShare Float    @default(0)
  platformTokenFeeTokenTreasuryShare Float  @default(0)
  liquidityTonAmount      Float         @default(0)
  creatorTreasuryAmount   Float         @default(0)
  social                  Json?
  pendingIndexing         Boolean       @default(true)
  lastIndexedAt           DateTime?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  transactions            Transaction[]
  holders                 Holder[]

  @@index([creatorWallet])
  @@index([status])
  @@index([createdAt])
  @@index([symbol])
}

model Transaction {
  id            String          @id @default(cuid())
  launchId      String
  walletAddress String
  txHash        String          @unique
  type          TransactionType
  amountTon     Float          @default(0)
  tokenAmount   Float          @default(0)
  timestamp     DateTime       @default(now())

  launch        Launch         @relation(fields: [launchId], references: [id], onDelete: Cascade)

  @@index([walletAddress])
  @@index([txHash])
  @@index([type])
  @@index([timestamp])
}

model Holder {
  id            String   @id @default(cuid())
  launchId      String
  walletAddress String
  tokenBalance  Float    @default(0)
  updatedAt     DateTime @updatedAt

  launch        Launch   @relation(fields: [launchId], references: [id], onDelete: Cascade)

  @@unique([launchId, walletAddress])
  @@index([walletAddress])
}

model StatsCache {
  id                String   @id @default("global")
  tokensLaunched    Int      @default(0)
  totalRaisedTon    Float    @default(0)
  activeHolders     Int      @default(0)
  volume24hTon      Float    @default(0)
  updatedAt         DateTime @updatedAt
}
