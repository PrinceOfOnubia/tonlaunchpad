{
  "name": "tonpad",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "backend:dev": "tsx backend/src/server.ts",
    "backend:build": "tsc -p backend/tsconfig.json",
    "backend:start": "npm run backend:prisma:migrate && npm run backend:start:server",
    "backend:start:server": "node backend/dist/server.js",
    "backend:prisma:generate": "prisma generate --schema backend/prisma/schema.prisma",
    "backend:prisma:migrate": "prisma migrate deploy --schema backend/prisma/schema.prisma",
    "contract:build": "tact --config tact.config.json --project Launchpad --quiet",
    "contract:test": "npm run contract:build --silent && jest --runInBand",
    "test": "npm run contract:test",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@tact-lang/compiler": "1.6.13",
    "@ton/blueprint": "0.44.2",
    "@ton/sandbox": "0.42.0",
    "@ton/test-utils": "0.12.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.15.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "jest": "^29.7.0",
    "postcss": "^8.5.14",
    "prisma": "^6.19.1",
    "tailwindcss": "^3.4.17",
    "ts-jest": "^29.3.2",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@prisma/client": "^6.19.1",
    "@ton/core": "0.63.1",
    "@ton/ton": "^16.2.4",
    "@tonconnect/ui-react": "^2.4.4",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "lucide-react": "^1.14.0",
    "multer": "^2.0.2",
    "next": "^16.2.6",
    "pg": "^8.16.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.1.13",
    "zustand": "^5.0.13"
  }
}
